# Token de acesso privado do HubSpot (Settings > Integrations > Private Apps)
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Chave secreta para validar webhooks do GPT Maker (opcional mas recomendado)
GPTMAKER_WEBHOOK_SECRET=sua_chave_secreta_aqui

# API do GPT Maker para disparar mensagens ativas via WhatsApp
GPTMAKER_API_TOKEN=seu_token_aqui
GPTMAKER_WORKSPACE_ID=seu_workspace_id_aqui
GPTMAKER_FLOW_ID=id_do_fluxo_de_notificacao_aqui
GPTMAKER_AGENT_ID=id_do_agente_aqui
GPTMAKER_NOTIFICATION_AGENT_ID=id_do_agente_de_notificacao_aqui

# Porta do servidor
PORT=3000
